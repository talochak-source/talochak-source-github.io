<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tal Ochakovsky — CPA</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300;1,9..144,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0F0E0C;
      --bg2: #181612;
      --ink: #F0EDE6;
      --muted: #9A9690;
      --accent: #D4A853;
      --border: #2A2820;
      --serif: 'Fraunces', Georgia, serif;
      --sans: 'DM Sans', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--ink); font-family: var(--sans); font-size: 17px; line-height: 1.7; }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.2rem 5vw;
      background: rgba(15,14,12,0.88); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-family: var(--serif); font-size: 1.1rem; font-weight: 300; color: var(--ink); text-decoration: none; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { font-size: 0.82rem; color: var(--muted); text-decoration: none; letter-spacing: 0.04em; transition: color 0.2s; }
    .nav-links a:hover { color: var(--ink); }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: grid; grid-template-columns: 1.4fr 0.6fr;
      align-items: center; gap: 4rem;
      padding: 10rem 5vw 6rem;
      border-bottom: 1px solid var(--border);
    }
    .hero-tag {
      display: inline-block; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--accent); border: 1px solid var(--accent); padding: 0.3rem 0.8rem;
      border-radius: 999px; margin-bottom: 2rem;
      opacity: 0; animation: fadeUp 0.7s ease forwards 0.2s;
    }
    .hero h1 {
      font-family: var(--serif); font-size: clamp(2.8rem, 6vw, 5.2rem);
      font-weight: 300; line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 1.8rem;
      opacity: 0; animation: fadeUp 0.7s ease forwards 0.35s;
    }
    .hero h1 em { font-style: italic; color: var(--accent); }
    .hero-desc {
      font-size: 1.05rem; color: var(--muted); line-height: 1.85; max-width: 480px;
      margin-bottom: 2.5rem; font-weight: 300;
      opacity: 0; animation: fadeUp 0.7s ease forwards 0.5s;
    }
    .hero-desc strong { color: var(--ink); font-weight: 500; }
    .hero-buttons {
      display: flex; gap: 1rem; flex-wrap: wrap;
      opacity: 0; animation: fadeUp 0.7s ease forwards 0.65s;
    }
    .btn { display: inline-block; text-decoration: none; padding: 0.75rem 1.7rem; border-radius: 6px; font-size: 0.85rem; font-weight: 500; letter-spacing: 0.04em; transition: all 0.2s; }
    .btn-primary { background: var(--accent); color: #0F0E0C; }
    .btn-primary:hover { background: #C49840; }
    .btn-secondary { border: 1px solid var(--border); color: var(--muted); }
    .btn-secondary:hover { border-color: var(--muted); color: var(--ink); }

    .hero-right { opacity: 0; animation: fadeUp 0.9s ease forwards 0.5s; }
    .photo-frame {
      border-radius: 16px; overflow: hidden; aspect-ratio: 4/5;
      background: var(--bg2); border: 1px solid var(--border);
    }
    .photo-placeholder {
      width: 100%; height: 100%; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 1rem;
      color: var(--muted); font-size: 0.82rem; text-align: center; padding: 2rem;
    }
    .photo-placeholder svg { opacity: 0.25; }
    .photo-caption { margin-top: 1rem; font-size: 0.78rem; color: var(--muted); font-style: italic; text-align: center; }

    /* SECTIONS */
    section {
      padding: 7rem 5vw; border-bottom: 1px solid var(--border);
      opacity: 0; transform: translateY(24px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    section.visible { opacity: 1; transform: none; }
    .section-header { display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 4rem; }
    .section-num { font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); font-weight: 500; }
    .section-title { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3rem); font-weight: 300; line-height: 1.1; }
    .section-title em { font-style: italic; color: var(--muted); }

    /* ABOUT */
    .about-body { display: grid; grid-template-columns: 2fr 1fr; gap: 6rem; align-items: start; }
    .about-body p { font-size: 1.05rem; color: var(--muted); font-weight: 300; line-height: 1.9; margin-bottom: 1.2rem; }
    .about-body p strong { color: var(--ink); font-weight: 500; }
    .stat { padding: 1.4rem 0; border-bottom: 1px solid var(--border); }
    .stat-number { font-family: var(--serif); font-size: 2.2rem; font-weight: 700; color: var(--accent); line-height: 1; margin-bottom: 0.3rem; }
    .stat-label { font-size: 0.8rem; color: var(--muted); }

    /* EXPERIENCE */
    .exp-list { max-width: 720px; }
    .exp-item { display: grid; grid-template-columns: 90px 1fr; gap: 2.5rem; padding: 2.2rem 0; border-bottom: 1px solid var(--border); align-items: start; }
    .exp-item:last-child { border-bottom: none; }
    .exp-years { font-size: 0.72rem; color: var(--muted); letter-spacing: 0.06em; padding-top: 4px; }
    .exp-role { font-family: var(--serif); font-size: 1.25rem; font-weight: 400; margin-bottom: 0.3rem; }
    .exp-org { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); font-weight: 500; }

    /* EXPERTISE */
    .projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .project-card {
      background: var(--bg2); border: 1px solid var(--border); border-radius: 12px;
      padding: 2.5rem; transition: border-color 0.3s, transform 0.3s;
    }
    .project-card:hover { border-color: var(--accent); transform: translateY(-4px); }
    .project-icon { font-size: 2rem; margin-bottom: 1.2rem; display: block; }
    .project-card h3 { font-family: var(--serif); font-size: 1.2rem; font-weight: 400; margin-bottom: 0.8rem; }
    .project-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.75; font-weight: 300; }

    /* CONTACT */
    .contact-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
    .contact-inner h2 { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; line-height: 1.1; margin-bottom: 1.5rem; }
    .contact-inner h2 em { font-style: italic; color: var(--muted); }
    .contact-inner > div:first-child p { color: var(--muted); font-size: 1rem; font-weight: 300; line-height: 1.8; }
    .contact-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.5rem 0; border-bottom: 1px solid var(--border);
      text-decoration: none; color: var(--ink); transition: color 0.2s;
    }
    .contact-row:hover { color: var(--accent); }
    .contact-row-label { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.2rem; }
    .contact-row-value { font-size: 1rem; }
    .contact-arrow { font-size: 1.2rem; opacity: 0.4; }

    /* FOOTER */
    footer { padding: 2rem 5vw; display: flex; justify-content: space-between; align-items: center; }
    footer p { font-size: 0.75rem; color: var(--muted); }

    /* ── PHOTO ── */
    header { position: relative; }
    .hero-photo {
      position: absolute;
      top: 50%;
      right: 5vw;
      transform: translateY(-50%);
      width: clamp(160px, 20vw, 300px);
      aspect-ratio: 1;
      border-radius: 50%;
      overflow: hidden;
      border: 1px solid var(--rule);
      box-shadow: 0 20px 60px rgba(0,0,0,0.08);
    }
    .hero-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
    @media (max-width: 700px) {
      .hero-photo { position: static; transform: none; width: 100px; margin-bottom: 2rem; }
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: none; }
    }

    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; padding-top: 8rem; }
      .hero-right { order: -1; max-width: 280px; margin: 0 auto; }
      .about-body { grid-template-columns: 1fr; gap: 3rem; }
      .projects-grid { grid-template-columns: 1fr; }
      .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
      .exp-item { grid-template-columns: 1fr; gap: 0.3rem; }
    }
  </style>
</head>
